<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.seckill.mapper.MerchantMapper">

    <resultMap id="BaseResultMap" type="com.example.seckill.entity.Merchant">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="shop_name" property="shopName"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 插入商户 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO merchant(username, password, shop_name, phone, status, create_time, update_time)
        VALUES(#{username}, #{password}, #{shopName}, #{phone}, 1, NOW(), NOW())
    </insert>

    <!-- 根据商户名查询商户 -->
    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM merchant WHERE username = #{username}
    </select>

    <!-- 根据ID查询商户 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM merchant WHERE id = #{id}
    </select>


</mapper>